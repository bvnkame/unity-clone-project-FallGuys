{
  "name": "fall-guys-server",
  "version": "1.0.0",
  "description": "Colyseus multiplayer server for Fall Guys clone",
  "main": "src/index.ts",
  "scripts": {
    "start": "ts-node src/index.ts",
    "dev": "nodemon --watch src --ext ts --exec ts-node src/index.ts",
    "build": "tsc",
    "build:start": "npm run build && node dist/index.js"
  },
  "dependencies": {
    "@colyseus/monitor": "^0.15.0",
    "@colyseus/schema": "^2.0.37",
    "colyseus": "^0.15.0",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "nodemon": "^3.0.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.0"
  }
}
